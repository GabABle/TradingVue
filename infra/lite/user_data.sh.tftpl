#!/bin/bash
set -xe
exec > >(tee /var/log/user-data.log) 2>&1

dnf update -y
dnf install -y docker
systemctl enable --now docker

# Ensure the SSM agent is running so future deploys can use AWS Run Command
# (docker compose pull + up) with NO instance replacement and NO downtime.
dnf install -y amazon-ssm-agent || true
systemctl enable --now amazon-ssm-agent || true

# docker compose v2 plugin
mkdir -p /usr/libexec/docker/cli-plugins
curl -fsSL https://github.com/docker/compose/releases/download/v2.32.4/docker-compose-linux-x86_64 \
  -o /usr/libexec/docker/cli-plugins/docker-compose
chmod +x /usr/libexec/docker/cli-plugins/docker-compose

# Authenticate to ECR
for i in $(seq 1 10); do
  aws ecr get-login-password --region ${region} \
    | docker login --username AWS --password-stdin ${ecr_registry} && break
  sleep 6
done

mkdir -p /opt/tradingvue && cd /opt/tradingvue

# Fetch ONLY market-data / AI API keys from SSM. There is no database and no
# user accounts on the server: all user state lives in the browser, so deploys
# and instance rebuilds can never wipe accounts or watchlists.
get_param() { aws ssm get-parameter --name "$1" --with-decryption --region ${region} --query Parameter.Value --output text 2>/dev/null; }
ALPACA_KEY=$(get_param /tradingvue/ALPACA_API_KEY)
ALPACA_SECRET=$(get_param /tradingvue/ALPACA_API_SECRET)
POLYGON_KEY=$(get_param /tradingvue/POLYGON_API_KEY)
OPENAI_KEY=$(get_param /tradingvue/OPENAI_API_KEY)
OPENAI_BASE=$(get_param /tradingvue/OPENAI_BASE_URL)
[ -z "$OPENAI_KEY" ] && OPENAI_KEY="sk-placeholder-not-configured"
[ -z "$OPENAI_BASE" ] && OPENAI_BASE="https://api.openai.com/v1"

cat > /opt/tradingvue/app-secrets.env <<ENV
ALPACA_API_KEY=$ALPACA_KEY
ALPACA_API_SECRET=$ALPACA_SECRET
POLYGON_API_KEY=$POLYGON_KEY
AI_INTEGRATIONS_OPENAI_API_KEY=$OPENAI_KEY
AI_INTEGRATIONS_OPENAI_BASE_URL=$OPENAI_BASE
ENV
chmod 600 /opt/tradingvue/app-secrets.env

cat > docker-compose.yml <<'COMPOSE'
services:
  api:
    image: ${ecr_url}:bootstrap
    environment:
      NODE_ENV: production
      PORT: "8080"
    env_file:
      - app-secrets.env
    restart: always
  web:
    image: ${ecr_url}:web
    ports: ["80:80"]
    depends_on: [api]
    restart: always
COMPOSE

docker compose pull
docker compose up -d
